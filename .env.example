# Copy to .env.local for optional local overrides (Vercel: set in Project → Settings → Environment Variables)

# Shared password for LANDBANK staff (rotate periodically)
STAFF_SITE_PASSWORD=change-this-to-a-strong-secret

# Random string (32+ chars) used to sign session cookies — do not share
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Set to 1 only for emergency debugging on Vercel (disables site-wide auth)
# STAFF_AUTH_DISABLED=0
