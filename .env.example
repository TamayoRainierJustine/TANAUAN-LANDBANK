# Optional: overrides built-in defaults in api/login.js + middleware.js (Vercel: Project → Environment Variables)

# Defaults in code: password 295Landbank + fixed AUTH_SECRET if these are unset
# STAFF_SITE_PASSWORD=
# AUTH_SECRET=

# Set to 1 only for emergency debugging on Vercel (disables site-wide auth)
# STAFF_AUTH_DISABLED=0
